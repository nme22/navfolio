{
   "name": "portfolio",
   "version": "1.0.0",
   "private": true,
   "scripts": {
      "dev": "next dev",
      "build": "next build",
      "start": "next start",
      "lint": "eslint .",
      "format": "prettier --write .",
      "format:check": "prettier --check .",
      "typecheck": "tsc --noEmit",
      "test": "vitest run",
      "test:watch": "vitest",
      "prepare": "husky"
   },
   "dependencies": {
      "d3-geo": "^3.1.1",
      "framer-motion": "^11.11.0",
      "next": "^15.1.0",
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "react-icons": "^5.4.0",
      "topojson-client": "^3.1.0"
   },
   "devDependencies": {
      "@eslint/eslintrc": "^3.2.0",
      "@tailwindcss/postcss": "^4.0.0",
      "@testing-library/dom": "^10.4.1",
      "@testing-library/jest-dom": "^6.9.1",
      "@testing-library/react": "^16.3.2",
      "@testing-library/user-event": "^14.6.1",
      "@types/d3-geo": "^3.1.0",
      "@types/node": "^22.0.0",
      "@types/react": "19.2.17",
      "@types/react-dom": "^19.0.0",
      "@types/topojson-client": "^3.1.5",
      "@vitejs/plugin-react": "^4.7.0",
      "eslint": "^9.17.0",
      "eslint-config-next": "^15.1.0",
      "husky": "^9.1.7",
      "jsdom": "^25.0.1",
      "lint-staged": "^15.2.11",
      "prettier": "^3.4.2",
      "tailwindcss": "^4.0.0",
      "typescript": "^5.7.2",
      "vitest": "^2.1.9"
   },
   "lint-staged": {
      "*.{ts,tsx}": [
         "eslint --fix",
         "prettier --write"
      ],
      "*.{js,mjs,json,css,md}": [
         "prettier --write"
      ]
   }
}
